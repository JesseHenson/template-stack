# App
DEBUG=true
CORS_ORIGINS=http://localhost:5173

# Database (local default works with docker compose)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/template_stack

# Clerk (optional for local dev — leave empty to use dev user bypass)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=

# Anthropic
ANTHROPIC_API_KEY=

# LiteLLM (optional)
LITELLM_API_KEY=
LITELLM_API_BASE=

# Inngest (optional)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Redis / Upstash (optional)
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# Sentry (optional)
SENTRY_DSN=

# LangSmith (optional)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# Frontend (Vite)
VITE_CLERK_PUBLISHABLE_KEY=
